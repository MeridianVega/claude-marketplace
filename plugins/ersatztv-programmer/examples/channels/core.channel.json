{
  "_comment": "core bucket — stable network-style channel. Daily refresh re-emits the next 24h against the channel's theme. 1080p HEVC 10-bit, 2 Mbps target. Adjust accel + vaapi_* for your hardware.",
  "playout": {
    "folder": "./channels/{N}/playout",
    "virtual_start": null
  },
  "ffmpeg": {
    "ffmpeg_path": "",
    "ffprobe_path": "",
    "disabled_filters": []
  },
  "normalization": {
    "audio": {
      "format": "aac",
      "bitrate_kbps": 192,
      "buffer_kbps": 384,
      "channels": 2,
      "sample_rate_hz": 48000,
      "normalize_loudness": true,
      "loudness": {
        "integrated_target": -16,
        "range_target": 11,
        "true_peak": -1.5
      }
    },
    "video": {
      "format": "hevc",
      "bit_depth": 10,
      "width": 1920,
      "height": 1080,
      "bitrate_kbps": 2000,
      "buffer_kbps": 4000,
      "accel": "",
      "tonemap_algorithm": "linear",
      "vaapi_device": "/dev/dri/renderD128",
      "vaapi_driver": "iHD"
    }
  }
}
