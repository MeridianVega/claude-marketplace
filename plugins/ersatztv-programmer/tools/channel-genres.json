{
  "_comment": "Per-channel METADATA filters — genre, era, path, exclusions. The rebuild agent queries Jellyfin fresh each night and picks items matching these rules. NO hardcoded series whitelists — the library evolves; the agent reasons about each item's metadata against these filters and decides what fits where.",

  "_global_exclusions": {
    "_": "Applied to EVERY non-holiday channel (31/32/33). Holiday content NEVER appears outside its dedicated channel.",
    "path_excludes": [
      "/Halloween/", "/Christmas/", "/Thanksgiving/", "/Holiday/",
      "/Hallmark/", "/Xmas/"
    ],
    "title_substrings_excludes_video": [
      "Christmas", "Xmas", "Halloween", "Thanksgiving", "Hanukkah",
      "Easter Special", "Valentine's", "St. Patrick's", "4th of July",
      "Independence Day Special", "New Year's"
    ],
    "_audio_files_": "Audio files (.mp3/.flac/.m4a) are exempt from title-substring checks — songs with 'Christmas' in lyrics are not holiday programming. Audio is only excluded when the path contains a holiday folder (/Christmas/, /Holiday Album/)."
  },

  "_field_reference": {
    "tv_genres_any": "TV episode pool — any of these genres",
    "tv_genres_all": "TV episode pool — must match all listed genres",
    "tv_excluded_genres": "TV episode rejected if any match",
    "tv_excluded_series": "Series-name blacklist for known bad fits (e.g., preschool shows on Adult Animation)",
    "movie_genres_any": "Movie pool — any of these genres",
    "movie_genres_all": "Movie pool — must match all listed genres",
    "movie_excluded_genres": "Movie rejected if any match",
    "movie_year_range": "[start_year, end_year] inclusive",
    "movie_path_contains": "Path substring match (case-insensitive). Use for studio-specific channels (Disney, A24)",
    "tv_path_contains": "Path substring match for TV (e.g., /Nickelodeon/)",
    "min_runtime_minutes": "Floor on item duration",
    "max_runtime_minutes": "Cap on item duration"
  },

  "1": {
    "name": "Primetime",
    "_": "Hand-built canonical channel — the rebuild agent uses project_ersatztv_primetime_canonical memory for slot decisions, not these filters."
  },

  "2": {"name": "Background", "tv_genres_any": ["Comedy","Drama","Adventure"], "tv_excluded_genres": ["Reality","News","Talk","Game-Show"]},
  "3": {"name": "Friends", "tv_genres_any": ["Comedy"], "_note": "Channel character: classic 90s-2000s sitcoms. Agent picks Friends + similar."},
  "4": {"name": "Adult Animation", "tv_genres_any": ["Animation","Comedy"], "tv_excluded_series": ["Bluey","Doc McStuffins","Mickey Mouse Clubhouse","Peppa Pig","Daniel Tiger","Sesame Street","PAW Patrol","Dora the Explorer","Octonauts","Cocomelon"], "_note": "Adult/teen animation — exclude preschool blacklist explicitly."},
  "5": {"name": "Saturday Morning", "tv_genres_any": ["Animation","Family"], "tv_excluded_genres": ["Anime"], "_note": "Western animation, kid-friendly, 90s vibe. Agent prefers items matching that era."},
  "6": {"name": "Action", "movie_genres_any": ["Action","Thriller"], "tv_genres_any": ["Action","Thriller"]},
  "7": {"name": "Adventure", "movie_genres_any": ["Adventure"], "tv_genres_any": ["Adventure"]},
  "8": {"name": "Comedy", "movie_genres_any": ["Comedy"], "tv_genres_any": ["Comedy"], "movie_excluded_genres": ["Horror"], "tv_excluded_genres": ["Horror"]},
  "9": {"name": "Drama", "movie_genres_any": ["Drama"], "tv_genres_any": ["Drama"], "movie_excluded_genres": ["Comedy"], "_note": "Drama-only — comedies belong on ch8."},
  "10": {"name": "Family", "tv_genres_any": ["Family"], "movie_genres_any": ["Family"], "tv_excluded_genres": ["Horror"], "movie_excluded_genres": ["Horror","Crime"]},
  "11": {"name": "Horror", "movie_genres_all": ["Horror"], "tv_genres_all": ["Horror"]},
  "12": {"name": "Romance", "movie_genres_all": ["Romance"], "tv_genres_all": ["Romance"]},
  "13": {"name": "Scifi", "movie_genres_any": ["Sci-Fi","Science Fiction"], "tv_genres_any": ["Sci-Fi","Science Fiction"]},
  "14": {"name": "Western", "movie_genres_all": ["Western"], "tv_genres_all": ["Western"]},
  "15": {"name": "Documentary", "movie_genres_all": ["Documentary"], "tv_genres_all": ["Documentary"]},
  "16": {"name": "Anime", "tv_genres_any": ["Anime"], "tv_path_contains": ["/Anime/"], "_note": "Anime ONLY — Japanese animation. Agent uses genre OR path match."},
  "17": {"name": "Animated", "tv_genres_any": ["Animation"], "tv_excluded_genres": ["Anime"], "_note": "Western/Disney/Pixar animation, NOT anime (anime has its own ch16)."},
  "18": {"name": "Cooking TV", "tv_genres_any": ["Reality","Documentary"], "tv_path_contains": ["Cooking","Food","Chef","Bake"], "_note": "Cooking-themed reality + docs. Agent prefers items where path or series-name suggests cooking."},
  "19": {"name": "Nature", "tv_genres_all": ["Documentary"], "tv_path_contains": ["Nature","Earth","Wild","Cosmos","Planet","NOVA"], "_note": "Nature/science docs."},
  "20": {"name": "Disney & Pixar", "movie_path_contains": ["Disney","Pixar"], "tv_path_contains": ["Disney"], "_note": "Path filter — Disney/Pixar catalog only."},
  "21": {"name": "Ghibli", "movie_path_contains": ["Ghibli","Miyazaki","Takahata","Hosoda"], "movie_genres_any": ["Animation"], "_note": "Ghibli + adjacent Japanese auteurs."},
  "22": {"name": "Nickelodeon", "tv_path_contains": ["Nickelodeon"], "_note": "Path filter — Nick library only."},
  "23": {"name": "Cartoon Network", "tv_path_contains": ["Cartoon Network"], "_note": "Path filter — CN library only."},
  "24": {"name": "HBO Style", "tv_genres_any": ["Drama","Crime","Mystery"], "min_runtime_minutes": 45, "_note": "Prestige drama tier — long-form episodes (45min+) suggesting premium production."},
  "25": {"name": "The Vault", "movie_year_range": [1940, 1979], "movie_genres_any": ["Drama","Mystery","Thriller"]},
  "26": {"name": "Classic Cinema", "movie_year_range": [1930, 1969]},
  "27": {"name": "80s Rewind", "movie_year_range": [1980, 1989]},
  "28": {"name": "90s Throwback", "movie_year_range": [1990, 1999]},
  "29": {"name": "2000s Replay", "movie_year_range": [2000, 2009]},
  "30": {"name": "Now Showing", "movie_year_range": [2018, 2026]},

  "31": {"name": "Halloween", "_holiday_": true, "_seasonal_window_": ["09-15","10-31"], "path_includes": ["/Halloween/"], "title_substrings": ["Halloween","Hocus Pocus","Trick"]},
  "32": {"name": "Thanksgiving", "_holiday_": true, "_seasonal_window_": ["11-15","11-30"]},
  "33": {"name": "Christmas", "_holiday_": true, "_seasonal_window_": ["12-01","12-26"], "path_includes": ["/Christmas/","/Xmas/"], "title_substrings": ["Christmas","Xmas","Hanukkah"]},

  "34": {"name": "24/7 Wrestling", "path_contains_any": ["/Wrestling/","ECW","WCW","Nitro"]},

  "100": {"name": "Wildcard", "_general_purpose_": true, "_note": "Agent picks anything fresh — newly added, library standouts, etc. No genre filter."},
  "101": {"name": "Director Spotlight", "_dynamic_": "Per-month rotation set in state.json.current_director", "movie_genres_any": ["Drama","Action","Thriller","Mystery","Sci-Fi"]},
  "102": {"name": "Studio Spotlight", "_dynamic_": "Per-month rotation", "movie_genres_any": ["Drama","Comedy"]},
  "103": {"name": "Decade Deep Dive", "_dynamic_": "Per-month decade in state.json.current_decade"},
  "104": {"name": "Genre Sampler", "_dynamic_": "Per-month genre in state.json.current_genre"},
  "105": {"name": "Forgotten Greats", "movie_year_range": [1930, 1989], "_note": "Older underseen films."},
  "106": {"name": "Actor Carousel", "_dynamic_": "Per-month actor in state.json.current_actor"},
  "107": {"name": "Mood Board", "_general_purpose_": true, "movie_genres_any": ["Comedy","Romance","Family"], "_note": "Comfort viewing — gentle, low-stakes."},
  "108": {"name": "Soundtrack Cinema", "movie_genres_any": ["Drama","Adventure","Sci-Fi","Fantasy"], "min_runtime_minutes": 95, "_note": "Films with strong scores — long-form adventure/fantasy/sci-fi."},
  "109": {"name": "TV Showcase", "tv_genres_any": ["Drama","Comedy"], "_note": "Broad TV showcase — agent rotates between strong series."},

  "200": {"name": "80s FM",        "audio_genres_any": ["Pop","Rock","New Wave","Synthwave"]},
  "201": {"name": "90s MTV",       "audio_genres_any": ["Alternative","Grunge","Hip Hop"]},
  "202": {"name": "2000s Hits",    "audio_genres_any": ["Pop","Punk","Hip Hop","Pop Punk"]},
  "203": {"name": "Morning Chill", "audio_genres_any": ["Easy Listening","Soft Rock","Bossa Nova","Acoustic","Jazz","Lounge","Folk","Singer-Songwriter"]},
  "204": {"name": "Late Night Beats","audio_genres_any": ["Electronic","Ambient","Downtempo","Trip Hop"]},
